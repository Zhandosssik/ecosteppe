# Скопируйте в .env и заполните значения:
#   cp .env.example .env   (или copy .env.example .env на Windows)

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Только Project URL из Settings → API (БЕЗ /rest/v1 в конце!)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth (Supabase Dashboard):
# - Authentication → Providers → Email: включить, Confirm email = ON
# - Authentication → Email Templates: в письме подтверждения использовать {{ .Token }} (OTP)
# - Authentication → Providers → Google: Client ID/Secret, Redirect URL:
#   http://localhost:3000/auth/callback  (и ваш production URL)
# - Authentication → URL Configuration → Site URL = NEXT_PUBLIC_APP_URL
#   Redirect URLs: http://localhost:3000/auth/callback

# Команды: 005_teams_management.sql
# Очистка фейковых данных: 010_remove_all_fake_data.sql
# Логотипы: 006_team_logos_storage.sql + SUPABASE_SERVICE_ROLE_KEY
# Профиль (настройки, аватары): 011_profile_settings.sql, 012_avatars_storage.sql

# ИИ: проверка мусора на фото (Groq — Llama 4 Scout vision)
# Ключ: https://console.groq.com/keys (начинается с gsk_)
GROQ_API_KEY=your-groq-api-key
# Опционально: meta-llama/llama-4-scout-17b-16e-instruct (по умолчанию)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Порог уверенности 0–1 для автопубликации заявок о загрязнении (по умолчанию 0.55)
GROQ_TRASH_CONFIDENCE_THRESHOLD=0.55
